<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<title>Babel — Tower of Babel</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',system-ui,sans-serif;background:#0a0604;color:#e8ddd0;display:flex;justify-content:center;align-items:center;min-height:100vh;min-height:100dvh;user-select:none;overflow:hidden;touch-action:manipulation;-webkit-tap-highlight-color:transparent}
#game{width:100vw;height:100vh;height:100dvh;max-width:100vw;max-height:100dvh;display:flex;flex-direction:column;background:linear-gradient(135deg,#120a06,#0d0704);overflow:hidden;position:relative;font-size:16px}

/* ── TOP BAR ── */
#bar{padding:3px 8px;background:linear-gradient(180deg,#1a0e08,#0d0704);border-bottom:1px solid #2a180e;flex-shrink:0;z-index:10}
#bar-top{display:flex;justify-content:space-between;align-items:center;gap:6px}
#bar-top h1{font-size:15px;font-weight:800;color:#e8c87a;letter-spacing:1px;white-space:nowrap;text-shadow:0 1px 3px rgba(0,0,0,0.5)}
#bar-top h1 span{color:#d4a04a}
#bar-top .st{display:flex;gap:6px;font-size:12px;color:#7a5a3a;flex-wrap:wrap;align-items:center}
#bar-top .st b{color:#e8ddd0}
#bar-top .st .gold{color:#ffd700}
#bar-top .st .hgt{color:#70b0d0}

/* ── XP BARS ── General on top, 3 skills in a 2x container below */
#xp-strip{flex-shrink:0;background:rgba(0,0,0,0.25);border-bottom:1px solid #1a0e08;padding:2px 6px;display:flex;flex-direction:column;gap:2px}
#xp-general{flex-shrink:0}
#xp-general .xpr{display:flex;align-items:center;gap:4px;height:14px;padding:0 4px}
#xp-skills{flex:1;min-height:0;display:flex;flex-direction:column;gap:1px;padding:0}
#xp-skills .xpr{display:flex;align-items:center;gap:4px;padding:0 4px;flex:1;min-height:0;transition:flex 0.3s ease}
.xpr .xlb{font-size:9px;font-weight:700;width:18px;text-align:center;flex-shrink:0}
.xpr .xn{font-size:9px;font-weight:600;width:58px;flex-shrink:0;color:#8a7a6a;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.xpr .xbarw{flex:1;height:4px;background:#0a0604;border-radius:2px;overflow:hidden;min-width:10px;position:relative}
.xpr .xbarw .xf{height:100%;border-radius:2px;transition:width 0.3s ease;position:absolute;left:0;top:0;width:0%}
.xpr .xbarw .xfo{height:100%;border-radius:2px;position:absolute;left:0;top:0;width:0%;transition:width 0.4s ease,opacity 0.5s ease;opacity:0}
.xpr .xbarw .xfo.sh{opacity:1}
.xpr .xlv{font-size:9px;font-weight:700;width:14px;text-align:right;flex-shrink:0}

/* ── TABS ── */
#tabs{display:flex;background:#0a0604;border-bottom:2px solid #2a180e;flex-shrink:0;z-index:10;overflow-x:auto}
#tabs .t{flex:1;padding:9px 6px;background:none;color:#5a3a2a;border:none;cursor:pointer;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;transition:all 0.1s;border-bottom:3px solid transparent;font-family:inherit;white-space:nowrap;min-width:0}
#tabs .t:hover{color:#d4a04a}
#tabs .t.on{color:#e8c87a;border-bottom-color:#e8c87a;background:rgba(232,200,122,0.04)}

/* ── CONTENT ── */
#content{flex:1;position:relative;min-height:0;overflow:hidden}
.pane{position:absolute;inset:0;display:none;flex-direction:column;overflow-y:auto;-webkit-overflow-scrolling:touch;background:radial-gradient(ellipse at 50% 0%, #150c08 0%, #0a0604 100%)}
.pane.on{display:flex}
.pane::-webkit-scrollbar{width:3px}.pane::-webkit-scrollbar-track{background:#0a0604}.pane::-webkit-scrollbar-thumb{background:#2a180e;border-radius:3px}

.g-res{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;padding:4px 6px;flex-shrink:0}
.g-res .r{background:rgba(15,10,6,0.8);border:1px solid #1a0e08;border-radius:4px;padding:4px 5px;display:flex;justify-content:space-between;align-items:center;font-size:12px}
.g-res .r .i{font-size:16px}.g-res .r .n{flex:1;font-size:11px;color:#8a6a4a;margin-left:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.g-res .r .v{font-weight:700;font-size:13px;color:#e8ddd0}.g-res .r.glow{border-color:#5a3a1a;background:rgba(30,18,8,0.9)}
.g-res .r .ps{font-size:9px;color:#4a6a3a}.g-res .r.locked{opacity:0.2}


.feed{position:absolute;font-weight:700;pointer-events:none;animation:feedUp 0.8s ease forwards;z-index:20;text-align:center;line-height:1}
.feed .l1{display:block;font-size:17px;margin-bottom:2px}.feed .l2{display:block;font-size:12px}
@keyframes feedUp{0%{opacity:1;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(-40px) scale(1.06)}}
@keyframes celebPulse{0%{transform:scale(1);opacity:1}50%{transform:scale(1.15);opacity:0.8}100%{transform:scale(1);opacity:1}}
@keyframes glowPulse{0%{box-shadow:0 0 3px rgba(232,200,122,0.1)}50%{box-shadow:0 0 12px rgba(232,200,122,0.25)}100%{box-shadow:0 0 3px rgba(232,200,122,0.1)}}
@keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-6px)}40%{transform:translateX(6px)}60%{transform:translateX(-4px)}80%{transform:translateX(4px)}}
@keyframes sparkle{0%{opacity:0;transform:translateY(0) scale(0) rotate(0deg)}50%{opacity:1;transform:translateY(-30px) scale(1) rotate(180deg)}100%{opacity:0;transform:translateY(-60px) scale(0) rotate(360deg)}}

/* ── OPTIONS PANEL ── */
#options-panel{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:200;background:rgba(10,6,4,0.97);border:1px solid #3a2a1a;border-radius:10px;padding:10px 14px;min-width:240px;box-shadow:0 8px 40px rgba(0,0,0,0.8);display:none;backdrop-filter:blur(8px)}
#options-panel.sh{display:block}
#options-header{display:flex;justify-content:space-between;align-items:center;font-size:14px;font-weight:700;color:#e8c87a;margin-bottom:8px;padding-bottom:4px;border-bottom:1px solid #2a180e}
#options-close{font-size:16px;cursor:pointer;color:#6a4a2a;padding:0 4px}
#options-close:hover{color:#e8ddd0}
.opt-row{display:flex;justify-content:space-between;align-items:center;padding:5px 0;font-size:12px}
.opt-lbl{color:#b8a090}
.opt-tog{font-size:11px;font-weight:700;padding:3px 10px;border-radius:4px;cursor:pointer;background:#1a3a10;color:#60a060;border:1px solid #2a5a18;min-width:40px;text-align:center}
.opt-tog.off{background:#3a1010;color:#cc5050;border-color:#5a2020}
.opt-btn{font-size:11px;font-weight:600;padding:3px 10px;border-radius:4px;cursor:pointer;background:#1a0e08;color:#b8a090;border:1px solid #3a2a1a;min-width:40px;text-align:center}
.opt-btn:active{background:#2a1a10}

/* ── UPGRADES (shared tap & auto sections) ── */
.g-upgs,.c-upgs,.a-upgs{padding:3px 6px;flex-shrink:0;overflow-y:auto;max-height:30%}
.g-upgs{border-top:1px solid #1a0e08}
.c-upgs{border-top:1px solid #1a0e08;margin-top:2px}
.a-upgs{border-top:1px solid #2a2010;background:rgba(10,8,6,0.3)}
.g-upgs .uh,.c-upgs .uh,.a-upgs .uh{font-size:9px;text-transform:uppercase;letter-spacing:0.5px;margin:3px 0 2px;display:block}
.g-upgs .uh,.c-upgs .uh{color:#4a3a2a}
.a-upgs .uh{color:#5a6a3a;font-weight:700;text-shadow:0 0 6px rgba(80,180,50,0.08)}
.g-upgs .u,.c-upgs .u,.a-upgs .u{display:flex;justify-content:space-between;align-items:center;padding:3px 5px;margin-bottom:1px;background:rgba(0,0,0,0.2);border-radius:3px;font-size:11px}
.a-upgs .u{border-left:2px solid #5a8a3a;background:rgba(20,40,10,0.2)}
.g-upgs .u .d,.c-upgs .u .d,.a-upgs .u .d{flex:1;min-width:0}
.g-upgs .u .d .nm,.c-upgs .u .d .nm,.a-upgs .u .d .nm{font-weight:600;font-size:11px}
.g-upgs .u .d .dc,.c-upgs .u .d .dc,.a-upgs .u .d .dc{font-size:9px;color:#6a5a4a}
.g-upgs .u .co,.c-upgs .u .co,.a-upgs .u .co{font-size:10px;color:#ffd700;margin:0 3px;white-space:nowrap}
.g-upgs .u button,.c-upgs .u button,.a-upgs .u button{font-size:9px;padding:3px 6px;font-family:inherit;background:linear-gradient(135deg,#3a2010,#5a3018);color:#e8ddd0;border:1px solid #6a3820;border-radius:3px;cursor:pointer;white-space:nowrap}
.a-upgs .u button{background:linear-gradient(135deg,#1a3a10,#2a5a18);border-color:#3a6a28}
.g-upgs .u button:disabled,.c-upgs .u button:disabled,.a-upgs .u button:disabled{opacity:0.3;cursor:not-allowed}

/* ── CRAFT ── */
.c-recipes{padding:3px 6px;flex-shrink:0}
.c-recipes .ch{font-size:10px;text-transform:uppercase;color:#4a3a2a;margin:2px 0;display:block}
.c-recipes .cr{display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
.c-recipes .cr .ci{background:rgba(15,10,6,0.6);border:1px solid #1a0e08;border-radius:4px;padding:4px 3px;text-align:center;cursor:pointer;transition:all 0.1s;font-size:11px}
.c-recipes .cr .ci:hover{border-color:#3a2a1a}.c-recipes .cr .ci.on{border-color:#e8c87a;background:rgba(232,200,122,0.04)}
.c-recipes .cr .ci .cn{font-size:9px;color:#6a5a4a}.c-recipes .cr .ci.locked{opacity:0.2;cursor:default}

.cbar{width:80%;max-width:240px;height:10px;background:#0a0604;border-radius:5px;overflow:hidden;margin:3px auto;border:1px solid #2a180e;position:relative}
.cbar .cf{height:100%;background:linear-gradient(90deg,#c46a3a,#e8a050);border-radius:4px;transition:width 0.05s;position:absolute;left:0;top:0}

/* ── BUILD ── */
#build-pane canvas{display:block;width:100%;height:100%}
.bhud{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(0deg,rgba(10,6,4,0.97) 0%,rgba(10,6,4,0.85) 80%,transparent 100%);padding:6px 8px 8px;z-index:5;gap:3px;display:flex;flex-direction:column}
.bhud .sn{font-size:12px;font-weight:700;color:#e8c87a;text-shadow:0 1px 3px rgba(0,0,0,0.5)}
.bhud .pt{font-size:11px;color:#8a7a6a;display:flex;gap:10px}
.bhud .pt span{color:#e8ddd0}
.bhud .stab{height:5px;background:#0a0604;border-radius:3px;overflow:hidden;border:1px solid #1a0e08}
.bhud .stab .sf{height:100%;border-radius:2px;transition:width 0.3s;position:relative}

/* ── BIG TAP BUTTONS ── */
.tz{flex-shrink:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:10px;margin:0;background:linear-gradient(135deg,#1a0e08,#25140a);border-top:2px solid #3a2a1a;border-left:none;border-right:none;border-bottom:none;cursor:pointer;transition:all 0.08s;width:100%;aspect-ratio:1/1;max-height:30vh}
.tz{animation:glowPulse 3s ease-in-out infinite}
.tz:active{background:linear-gradient(135deg,#2a1a10,#3a2018);border-top-color:#5a4a3a;animation:none}
.tz .tz-icon{font-size:36px;margin-bottom:1px;filter:drop-shadow(0 2px 8px rgba(0,0,0,0.5))}
.tz .tz-hint{font-size:15px;font-weight:700;color:#e8c87a;text-shadow:0 1px 4px rgba(0,0,0,0.4)}
.tz .tz-sub{font-size:11px;color:#8a6a4a;margin-top:1px}
#build-tap-overlay{position:absolute;bottom:90px;left:4px;right:4px;z-index:6;border-radius:8px;height:48px;display:flex!important;flex-direction:row!important;aspect-ratio:auto;border-top:none}
.pane-body{flex:1;overflow-y:auto;min-height:0;-webkit-overflow-scrolling:touch}
.bhud .ah{font-size:11px;color:#c0a070}
.row{display:flex;gap:2px;flex-wrap:wrap}.row .dot{width:5px;height:5px;border-radius:1px;background:#1a0e08;border:1px solid #2a180e}
.row .dot.done{background:#c46a3a;border-color:#e8a050}.row .dot.crack{background:#cc3030;border-color:#cc5050;animation:pulse 0.3s infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 2px rgba(255,215,0,0.3)}50%{box-shadow:0 0 4px rgba(255,215,0,0.5)}}

#fb:active{transform:scale(0.95)}
#tower-tech{position:absolute;top:4px;right:4px;z-index:6}
#tower-tech button{background:rgba(10,6,4,0.85);border:1px solid #2a180e;border-radius:4px;padding:3px 6px;cursor:pointer;font-size:11px;color:#8a6a4a;font-family:inherit}
#tower-tech button:hover{color:#e8c87a;border-color:#e8c87a}
#ttech-panel{position:absolute;top:24px;right:4px;z-index:6;width:200px;background:rgba(10,6,4,0.96);border:1px solid #2a180e;border-radius:5px;padding:5px;display:none;backdrop-filter:blur(4px);max-height:60%;overflow-y:auto}
#ttech-panel.sh{display:block}
#ttech-panel .tu{display:flex;justify-content:space-between;align-items:center;padding:4px 5px;margin-bottom:2px;border-radius:3px;font-size:11px}
#ttech-panel .tu:hover{background:rgba(255,255,255,0.02)}#ttech-panel .tu .td{flex:1;min-width:0}
#ttech-panel .tu .td .tnm{font-weight:600;font-size:11px}#ttech-panel .tu .td .tdc{font-size:9px;color:#6a5a4a}
#ttech-panel .tu .tco{font-size:10px;color:#ffd700;margin:0 3px;white-space:nowrap}
#ttech-panel .tu button{font-size:9px;padding:2px 5px;font-family:inherit;background:linear-gradient(135deg,#3a2010,#5a3018);color:#e8ddd0;border:1px solid #6a3820;border-radius:3px;cursor:pointer;white-space:nowrap}
#ttech-panel .tu button:disabled{opacity:0.3;cursor:not-allowed}#ttech-panel .tuh{font-size:9px;text-transform:uppercase;color:#4a3a2a;margin:2px 0 2px;border-top:1px solid #1a0e08;padding-top:2px}

.sk-scroll{padding:5px}
.sk{background:rgba(15,10,6,0.6);border:1px solid #1a0e08;border-radius:4px;padding:4px 7px;margin-bottom:3px}
.sk .shdr{display:flex;justify-content:space-between;align-items:center}
.sk .shdr .sn{font-weight:700;font-size:13px}.sk .shdr .sl{font-size:11px;font-weight:600}
.sk .sbar{height:4px;background:#0a0604;border-radius:2px;margin:2px 0;overflow:hidden}
.sk .sbar .sf{height:100%;border-radius:2px;transition:width 0.2s}.sk .sxp{font-size:10px;color:#6a5a4a}

.ms-sec{margin:5px 0;padding:5px;border-radius:4px;background:rgba(15,10,6,0.4)}
.ms-sec .msh{font-size:12px;font-weight:700;margin-bottom:2px;display:flex;justify-content:space-between}
.ms-sec .msh span{font-size:10px;color:#6a5a4a}
.ms-sec .msg{display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:2px}
.ms-sec .msg .m{background:rgba(10,6,4,0.6);border:1px solid #1a0e08;border-radius:4px;padding:3px 4px;text-align:center;font-size:10px;cursor:pointer;transition:all 0.12s}
.ms-sec .msg .m:hover{border-color:#3a2a1a}.ms-sec .msg .m.unlocked{border-color:#3a5a3a;background:rgba(10,20,10,0.4)}
.ms-sec .msg .m.next{border-color:#ffd700;box-shadow:0 0 4px rgba(255,215,0,0.1)}
.ms-sec .msg .m .ml{font-size:12px;font-weight:800;color:#e8c87a}.ms-sec .msg .m .md{font-size:9px;color:#6a5a4a;line-height:1.2}
.ms-sec .msg .m .mb{font-size:9px;color:#4a7a4a}

.su{background:rgba(15,10,6,0.5);border-radius:4px;padding:4px;margin-top:4px}
.su h{font-size:10px;text-transform:uppercase;color:#4a3a2a;margin:2px 0 2px;display:block}
.su .u{display:flex;justify-content:space-between;align-items:center;padding:4px 5px;margin-bottom:2px;font-size:11px;background:rgba(0,0,0,0.2);border-radius:3px}
.su .u .d{flex:1;min-width:0}.su .u .d .nm{font-weight:600;font-size:11px}.su .u .d .dc{font-size:9px;color:#6a5a4a}
.su .u .co{font-size:10px;color:#ffd700;margin:0 3px;white-space:nowrap}
.su .u button{font-size:9px;padding:3px 6px;font-family:inherit;background:linear-gradient(135deg,#3a2010,#5a3018);color:#e8ddd0;border:1px solid #6a3820;border-radius:3px;cursor:pointer;white-space:nowrap}
.su .u button:disabled{opacity:0.3;cursor:not-allowed}

.t-scroll{padding:5px}.tg{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:3px}
.parapet{border:1px solid #1a0e08;border-radius:5px;padding:4px;background:rgba(15,10,6,0.6)}
.parapet .phdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:2px}
.parapet .phdr .pn{font-size:12px;font-weight:700}.parapet .phdr .pl{font-size:10px;font-weight:600}
.parapet .pdesc{font-size:9px;color:#6a5a4a;margin-bottom:2px}.parapet .pbar{height:3px;background:#0a0604;border-radius:2px;overflow:hidden;margin-bottom:2px}
.parapet .pbar .pf{height:100%;background:linear-gradient(90deg,#e8c87a,#ffd700);border-radius:2px;transition:width 0.2s}
.parapet .peff{font-size:9px;color:#8a7a6a;margin-bottom:2px}
.parapet button{width:100%;font-size:10px;padding:3px;font-family:inherit;background:linear-gradient(135deg,#3a2010,#5a3018);color:#e8ddd0;border:1px solid #6a3820;border-radius:3px;cursor:pointer}
.parapet button:disabled{opacity:0.3;cursor:not-allowed}
#notif{position:fixed;top:12px;left:50%;transform:translateX(-50%);z-index:100;background:rgba(10,6,4,0.95);border:1px solid #ffd700;border-radius:6px;padding:5px 12px;color:#e8c87a;font-weight:600;font-size:12px;text-align:center;max-width:250px;opacity:0;transition:opacity 0.12s;pointer-events:none;box-shadow:0 3px 12px rgba(0,0,0,0.6)}
#notif.sh{opacity:1}.prtcl{position:fixed;pointer-events:none;font-size:10px;animation:prtclFade 0.4s ease forwards;z-index:50}
@keyframes prtclFade{0%{opacity:1;transform:translateY(0) scale(0.5)}100%{opacity:0;transform:translateY(-30px) scale(1.2)}}
@media(min-width:768px){#game{width:480px;height:800px;border-radius:12px;border:1px solid #2a180e;box-shadow:0 8px 40px rgba(0,0,0,0.8)}}
</style>
</head>
<body>
<div id="game">
  <div id="bar">
    <div id="bar-top">
      <h1>🗼 <span>BABEL</span></h1>
      <span id="gear-btn" onclick="G.toggleOptions()" style="font-size:16px;cursor:pointer;flex-shrink:0">⚙️</span>
      <div class="st">
        <span class="gold">🪙<b id="st-gold">0</b></span><span id="db-indicator" style="font-size:9px;color:#ff6644"></span><span id="ul-indicator" style="font-size:9px;color:#44ff66"></span>
        <span>🧱<b id="st-bricks">0</b></span><span id="st-auto" style="font-size:10px;color:#5a8a3a"></span>
        <span class="hgt">🗼<b id="st-hgt">0</b></span>
      </div>
    </div>
    <div id="xp-strip">
      <div id="xp-general">
        <div class="xpr"><span class="xlb" style="color:#e0d0c0">⚡</span><span class="xn">General</span><div class="xbarw"><div class="xf" id="xpf-x" style="width:0%;background:#e0d0c0"></div><div class="xfo" id="xfo-x" style="background:#e0d0c0"></div></div><span class="xlv" id="xlv-x" style="color:#e0d0c0">1</span></div>
      </div>
      <div id="xp-skills">
        <div class="xpr" id="xp-g"><span class="xlb" style="color:#d06040">⛏️</span><span class="xn">Gather</span><div class="xbarw"><div class="xf" id="xpf-g" style="width:0%;background:#d06040"></div><div class="xfo" id="xfo-g" style="background:#d06040"></div></div><span class="xlv" id="xlv-g" style="color:#d06040">1</span></div>
        <div class="xpr" id="xp-c"><span class="xlb" style="color:#50b050">🔨</span><span class="xn">Craft</span><div class="xbarw"><div class="xf" id="xpf-c" style="width:0%;background:#50b050"></div><div class="xfo" id="xfo-c" style="background:#50b050"></div></div><span class="xlv" id="xlv-c" style="color:#50b050">1</span></div>
        <div class="xpr" id="xp-b"><span class="xlb" style="color:#5090d0">🧱</span><span class="xn">Build</span><div class="xbarw"><div class="xf" id="xpf-b" style="width:0%;background:#5090d0"></div><div class="xfo" id="xfo-b" style="background:#5090d0"></div></div><span class="xlv" id="xlv-b" style="color:#5090d0">1</span></div>
      
      <div class="xpr" id="xp-m">
