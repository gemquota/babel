// ─── TAP POSITION TRACKING ──────────────────────────────────────────
let lastTapX=0,lastTapY=0;
document.addEventListener('mousedown',e=>{lastTapX=e.clientX;lastTapY=e.clientY});
document.addEventListener('touchstart',e=>{const t=e.touches[0];lastTapX=t.clientX;lastTapY=t.clientY},{passive:true});

// ─── STATE HELPERS ────────────────────────────────────────────────────

function uL(id){return S.upg[id]||0}
function tL(id){return S.tal[id]||0}
function msG(id){return S.ms[id]||0}
function skLv(id){return S.sk[id]?.lv||1}
function xpN(lv){return Math.floor(50*lv*(1+lv*0.12))}
function aL(id){return S.auto[id]||0}
function lP(id){const v=S.pr?.[id]||0;const m4=tL('m4');return m4>0?v*(1+m4*0.05):v}
function towerMsClaimed(type){const tm=S.tower.tm||0;let c=0;for(let i=0;i<TOWER_MS.length;i++){if(tm&(1<<i)&&(!type||TOWER_MS[i].type===type))c++}const m3=tL('m3');return m3>0?c*(1+m3*0.1):c}
function burstLv(id){const u=BURST_UPG.find(x=>x.id===id);if(!u)return 0;const l=S.upg[id]||0;return l>=u.L?u.L:l}
function getBurstPower(){const lv=burstLv('bp');return 20+lv*20}
function getBurstSpeed(){const lv=burstLv('bs');return Math.max(10,50-lv*5)}
function getBurstCost(){const lv=burstLv('bc');return Math.max(0,20-lv*2)}
function getBurstCooldown(){const lv=burstLv('bcd');return Math.max(2,20-lv*2)}
function getBurstCharges(){const lv=burstLv('bch');return 1+lv}
function rechargeBurst(){const b=S.burst;if(!b)return;const maxCh=getBurstCharges();if(b.lchrg>=maxCh)return;const cd=getBurstCooldown()*1000;const since=Date.now()-(b.last||0);if(since>=cd){const gained=Math.floor(since/cd);const newCh=Math.min(maxCh,b.lchrg+gained);if(newCh>b.lchrg){b.lchrg=newCh;b.last=Date.now();if(b.chrg<b.lchrg)b.chrg=b.lchrg}}}
function burstBuyUpg(id){const u=BURST_UPG.find(x=>x.id===id);if(!u)return;const l=S.upg[id]||0;if(l>=u.L)return;const c=Math.floor(u.cb*Math.pow(u.cm||2.5,l));if((S.stat.gold||0)<c)return;S.stat.gold-=c;S.upg[id]=l+1;notif('🔧 '+u.n+' Lv.'+(l+1));updateUI()}

function checkTowerMs(){const h=S.tower.rows.length;let tm=S.tower.tm||0;let n=false;TOWER_MS.forEach((ms,i)=>{if(h>=ms.h&&!(tm&(1<<i))){tm|=1<<i;n=true;notif('🏗️ '+ms.b+'!')}});if(n){S.tower.tm=tm;updateUI()}}


function checkAch(){if(!S.ach)S.ach=[];ACHIEVEMENTS.forEach((a,i)=>{if(!S.ach.includes(i)&&a.ch()){S.ach.push(i);a.r();notif('🏆 '+a.n+': '+a.d)}})}
function countAch(){if(!S.ach)return 0;let n=0;for(let i=0;i<ACHIEVEMENTS.length;i++){if(S.ach.includes(i))n++}return n}

function showCeleb(skill,count){
  const names={'gathering':'⛏️','crafting':'🔨','building':'🧱','general':'⚡'};
  const cols={'gathering':GAT_COL,'crafting':CRA_COL,'building':BLD_COL,'general':GXP_COL};
  const icon=names[skill]||'✨';
  notif('<span style="color:'+(cols[skill]||GXP_COL)+'">'+icon+' Level Up! x'+(count||1)+'</span>');
  // Sparkle particles
  for(let i=0;i<8;i++){const p=document.createElement('div');p.className='prtcl';
    p.textContent=['✨','⭐','🌟','💫'][i%4];
    p.style.left=(10+Math.random()*80)+'vw';p.style.top=(20+Math.random()*40)+'vh';
    document.body.appendChild(p);setTimeout(()=>p.remove(),600)}
}

function rC(id){const s=S.sk[id];if(!s)return;let l=1,x=s.xp||0,m=0,oldLv=s.lv;while(x>=xpN(l)&&m<10000){x-=xpN(l);l++;m++}s.lv=l;if(l>oldLv){showCeleb(id,l-oldLv)}}
function fmt(n){if(typeof n!=='number')n=0;if(n>=1e9)return (n/1e9).toFixed(1)+'B';if(n>=1e6)return (n/1e6).toFixed(1)+'M';if(n>=1e4)return (n/1e3).toFixed(1)+'K';if(n<10&&n>0)return n.toFixed(1);return Math.floor(n).toString()}

// ─── XP OVERLAY & BARS ───────────────────────────────────────────────

const SKILL_IDS=['gathering','crafting','building'];
const SKILL_COLS={'gathering':GAT_COL,'crafting':CRA_COL,'building':BLD_COL,'general':GXP_COL};
const XP_FO=['xfo-g','xfo-c','xfo-b'];
const XP_XF=['xpf-g','xpf-c','xpf-b'];
const XP_IDS=['xp-g','xp-c','xp-b'];
let xpOverlayTimer=null;


function triggerXpOverlay(skill){
  if(!skill||skill==='general')return;
  const s=S.sk[skill];if(!s)return;
  const nx=xpN(s.lv);const pct=Math.min(100,Math.floor((s.xp||0)/nx*100));
  const col=SKILL_COLS[skill]||GXP_COL;

  // Show overlay on all 3 skill bars
  for(let i=0;i<3;i++){
    const fo=document.getElementById(XP_FO[i]);
    if(fo){fo.style.width=pct+'%';fo.style.background=col;fo.classList.add('sh')}
  }

  // Grow the boosted bar, shrink others
  for(let i=0;i<3;i++){
    const el=document.getElementById(XP_IDS[i]);
    if(el)el.style.flex=(SKILL_IDS[i]===skill?'4':'1');
  }

  clearTimeout(xpOverlayTimer);
  xpOverlayTimer=setTimeout(()=>{
    // Fade overlay
    for(let i=0;i<3;i++){
      const fo=document.getElementById(XP_FO[i]);
      if(fo)fo.classList.remove('sh');
    }
    // Restore equal flex
    for(let i=0;i<3;i++){
      const el=document.getElementById(XP_IDS[i]);
      if(el)el.style.flex='1';
    }
    // After fade, restore actual levels
    setTimeout(()=>updateXPBars(),500);
  },1200);
}

function updateXPBars(){
  SKILL_IDS.forEach((id,i)=>{
    const s=S.sk[id];if(!s)return;
    const nx=xpN(s.lv);const pct=Math.min(100,Math.floor((s.xp||0)/nx*100));
    const col=SKILL_COLS[id];
    const f=document.getElementById(XP_XF[i]);
    if(f){f.style.width=pct+'%';f.style.background=col}
  });
  // General bar
  const gs=S.sk.general;if(gs){
    const gnx=xpN(gs.lv);const gpct=Math.min(100,Math.floor((gs.xp||0)/gnx*100));
    const gf=document.getElementById('xpf-x');
    if(gf)gf.style.width=gpct+'%';
    const ms=S.sk.mastery;if(ms){const mnx=xpN(ms.lv);const mpct=Math.min(100,Math.floor((ms.xp||0)/mnx*100));const mf=document.getElementById('xpf-m');if(mf)mf.style.width=mpct+'%';const ml=document.getElementById('xlv-m');if(ml)ml.textContent=ms.lv}
  const gl=document.getElementById('xlv-x');
    if(gl)gl.textContent=gs.lv;
  }
  // Update skill levels in XP strip
  SKILL_IDS.forEach((id,i)=>{
    const el=document.getElementById('xlv-'+id.charAt(0));
    if(el)el.textContent=S.sk[id].lv;
  });
}

// ─── EARNING ──────────────────────────────────────────────────────────

function earnX(sk,base){
  let m=1;
  if(msG("general")>=2)m*=2;
  if(msG("general")>=8)m*=4;
  if(sk==="gathering"){const v=uL("sg1");if(v>0)m*=1+v}
  if(sk==="crafting"){const v=uL("sc1");if(v>0)m*=1+v}
  if(sk==="building"){const v=uL("sb1");if(v>0)m*=1+v}
  if(tL('d1')>0)m*=1+tL('d1')*0.15;if(tL('ge4')>0)m*=1+tL('ge4')*0.1;if(tL('m1')>0)m*=1+tL('m1')*0.05;
  const leg=S.stat.legacy||0;if(leg>0)m*=1+leg*0.01;
  const x=Math.floor(base*m);
  if(sk==='general'){S.sk.general.xp+=x;rC('general')}
  else{S.sk[sk].xp+=x;rC(sk);S.sk.general.xp+=Math.floor(x*0.5);rC('general')}
  updateXPBars();
  setTimeout(()=>triggerXpOverlay(sk),50);if(sk!=='general'&&sk!=='mastery'){S.sk.mastery.xp+=Math.floor(x*0.3);rC('mastery');setTimeout(()=>triggerXpOverlay('mastery'),60)}
}

// ─── GATHER ───────────────────────────────────────────────────────────

function gF(){const l=skLv('gathering');return RES_ALL.filter(r=>r.unlock<=l)[0]||RES_ALL[0]}

function gather(id){
  const r=RES_ALL.find(x=>x.id===id);if(!r)return;
  let base=r.y*DB;let m=1;let g=1;
  let mg=msG('gathering');if(mg>=1)g=Math.max(1,Math.round(g*(1+mg*0.5)));
  UPG_R.forEach(u=>{const l=uL(u.id);if(l>0)m+=u.v*l});
  if(tL('t3')>0)m+=tL('t3')*0.08;if(tL('ga3')>0)m+=tL('ga3')*0.2;
  const amount=Math.max(1,Math.floor(Math.abs(base*(1+m)))||1);
  S.res[id]=(S.res[id]||0)+amount;if(tL('ga2')>0&&Math.random()<tL('ga2')*0.05){const rare=Math.floor(amount*0.5);S.res[id]+=rare;}
  const gAmt=Math.max(1,Math.floor(g*(1+uL('g1')*0.5+uL('g2')*1+uL('g3')*2+uL('g4')*4)));
  S.stat.gold=(S.stat.gold||0)+Math.floor(gAmt*(1+lP('p7')*0.5)*(tL('ge4')>0?1+tL('ge4')*0.1:1)*(tL('t5')>0?1+tL('t5')*0.15:1));
  S.stat.totalClicks=(S.stat.totalClicks||0)+1;
  earnX('gathering',DB);checkAch();
  showFeed(GAT_COL,RES_COL,GOLD_COL,'+'+amount+'R','+'+gAmt+'🪙','+'+DB+'⛏️XP','+'+(Math.floor(DB*0.5))+'⚡XP');
  updateUI();
}

// ─── CRAFT ────────────────────────────────────────────────────────────

function autoCraft(){
  const mats=unlockedMat();
  // Try to craft the selected/advanced recipe first (excluding mortar)
  const bricks=mats.filter(m=>m.id!=='mortar'&&Object.entries(m.r).every(([k,v])=>(S.res[k]||0)>=v));
  if(bricks.length){
    const sel=S._selCraft?bricks.find(m=>m.id===S._selCraft):null;
    if(sel)return sel;
    const best=bricks.reduce((a,b)=>MAT_ALL.indexOf(a)>MAT_ALL.indexOf(b)?a:b);
    S._selCraft=best.id;return best
  }
  // Fall back to mortar if we can
  const mort=mats.find(m=>m.id==='mortar');
  if(mort&&Object.entries(mort.r).every(([k,v])=>(S.res[k]||0)>=v))return mort;
  return null
}

function craft(mat){
  if(!mat)return;
  const r=mat.r;
  for(const[k,v]of Object.entries(r)){if(!DB_UNLIMITED&&(S.res[k]||0)<v)return}
  let b=DB;
  let mc=msG('crafting');if(mc>=1)b=Math.max(1,Math.round(b*(1+mc*0.5)));if(tL('cr2')>0)b=Math.floor(b*(1+tL('cr2')*0.15));
  let save=0;if(tL('t3')>0)save=Math.min(0.5,tL('t3')*0.08);
  if(!DB_UNLIMITED)for(const[k,v]of Object.entries(r)){S.res[k]-=v;if(save>0&&Math.random()<save)S.res[k]+=1}
  let amount=Math.max(1,b||1);
  S.mat[mat.id]=(S.mat[mat.id]||0)+amount;
  const g=Math.max(1,Math.floor(mat.t*(1+uL('c1')*0.5+uL('c2')*1+uL('c3')*2+uL('c4')*4)));
  S.stat.gold=(S.stat.gold||0)+Math.floor(g*(1+lP('p7')*0.5)*(tL('ge4')>0?1+tL('ge4')*0.1:1)*(tL('t5')>0?1+tL('t5')*0.15:1));
  S.stat.totalClicks=(S.stat.totalClicks||0)+1;
  earnX('crafting',2*DB);
  showFeed(CRA_COL,RES_COL,GOLD_COL,'+'+amount+mat.i,'+'+g+'🪙','+'+2*DB+'🔨XP','+'+(Math.floor(2*DB*0.5))+'⚡XP');
  updateUI();
}

function unlockedRes(){const l=skLv('gathering');return RES_ALL.filter(r=>r.unlock<=l)}
function unlockedMat(){const l=skLv('crafting');return MAT_ALL.filter(m=>m.unlock<=l)}

// ─── BUILD ────────────────────────────────────────────────────────────

function getBaseW(){let w=20+lP('p2');const tmw=towerMsClaimed('width');if(tmw>0)w=Math.floor(w*(1+tmw*0.1));[null,'bw1','bw2','bw3','bw4','bw5','bw6','bw7'].forEach(t=>{if(t&&S.tech[t])w=S.tech[t]});return w}
function getReinf(){let b=0+lP('p3')*0.03;['rf1','rf2','rf3','rf4','rf5','rf6','rf8','rf8'].forEach(id=>{if(S.tech[id])b+=TECH.find(t=>t.id===id).val});
  b*=1+tL('f1')*0.1;if(tL('bl3')>0)b*=1+tL('bl3')*0.1;
  if(msG('gathering')>=4||msG('crafting')>=4||msG('building')>=4||msG('general')>=4)b+=0.2;
  if(msG('gathering')>=8||msG('crafting')>=8||msG('building')>=8||msG('general')>=8)b+=0.3;return b}
function getFound(){let m=1;const tmf=towerMsClaimed('foundation');if(tmf>0)m*=Math.pow(2,tmf);['fd1','fd2','fd3','fd4','fd6','fd6'].forEach(id=>{if(S.tech[id])m+=TECH.find(t=>t.id===id).val});return m}
function getMatStr(){const m=MAT_ALL.find(x=>x.id===getMatId());return m?m.str:1.0}
function getStab(){const h=S.tower.rows.length;if(h===0)return{s:100,p:100,m:1};
  const bw=getBaseW(),ri=getReinf(),fd=getFound(),ms=getMatStr();
  const tpVal=S.tech.tp1||0;const bMs=msG('building');const maxSafe=bw*5+25+ri*30+fd*10+tpVal+bMs*2;if(maxSafe<=0)return{s:0,p:0,m:1};
  const p=Math.max(0,Math.min(100,100-((h/maxSafe)*100)));
  const tms=towerMsClaimed('stability');if(tms>0)p=Math.min(100,p+tms*5);const buildMs=msG('building');if(buildMs>0)p=Math.min(100,p+buildMs*3);const hp=Math.max(0.1,1-p/100);
  const tmAdj=tL('t2')>0||tL('t4')>0?Math.max(0.5,1-(tL('t2')*0.02+tL('t4')*0.012)):1;const m2b=tL('m2')*0.02;return{s:p,p:p,m:ms*tmAdj*(1+ri+m2b)}}
function getMatId(){const l=skLv('crafting');if(l>=18)return'megalith';if(l>=12)return'glazedBrick';if(l>=10)return'concrete';if(l>=8)return'reinfBrick';if(l>=6)return'stoneBlock';if(l>=3)return'firedBrick';return'mudBrick'}





function initTower(){
  // Fresh start resources (boosted by prestige)
  const prLvl=lP('p6');S.res.mud=50+prLvl*5;S.res.straw=20+prLvl*5;S.res.sand=30+prLvl*5;S.res.water=30+prLvl*5;S.res.lime=10+prLvl*5;
  S.mat.mortar=20;S.mat.mudBrick=50;S.stat.gold=(S.stat.gold||0)+500+lP('p1')*100;
  S.tower.rows=[];S.tower._coll=false;S.tower.lastRowTime=0;
  const bw=getBaseW();const row={bricks:[]};
  for(let i=0;i<bw;i++)row.bricks.push({st:'e'});
  S.tower.rows.push(row);
  
}

function tapBuild(){
  if(S.tower._coll){notif('💥 Collapsed! Rebuild?');initTower();updateUI();return}
  const mat=getMatId();if(!mat){notif('Need materials!');return}
  const bw=getBaseW();
  let rows=S.tower.rows;if(!rows.length)rows.push({bricks:[],t:Date.now()});
  let row=rows[rows.length-1];
  
  // Fill any missing slots with empty state
  while(row.bricks.length<bw)row.bricks.push({st:'e'});
  
  // Find the first brick slot that needs work
  let slot=row.bricks.findIndex(b=>b.st!=='d');
  if(slot<0){
    // Row is complete - check stability and start new row
    const st=getStab();
    if(st.p<=0||(st.p<5&&Math.random()<0.05/(towerMsClaimed('repair')>0?3:1))){
      S.tower._coll=true;S.tower.collapses=(S.tower.collapses||0)+1;S.stat.legacy=Math.max(S.stat.legacy||0,Math.floor((S.stat.tallest||rows.length)*(0.1+lP('p4')*0.005)));
  const shardGain=Math.floor((S.stat.tallest||rows.length)/25)+Math.floor((S.stat.legacy||0)/10);
  if(shardGain>0){S.stat.shards=(S.stat.shards||0)+shardGain;earnX('mastery',Math.floor(DB*5*(1+Math.floor(rows.length/50))));notif('💥 TOWER COLLAPSED! +'+(S.stat.legacy||0)+'% legacy +💎'+shardGain+' shards!')}else{notif('💥 TOWER COLLAPSED! +'+(S.stat.legacy||0)+'% legacy!')}
  document.getElementById('game').style.animation='shake 0.5s ease';setTimeout(()=>document.getElementById('game').style.animation='',500);
      S.stat.gold=(S.stat.gold||0)+Math.floor(Math.max(50,50+rows.length*10+S.stat.totalClicks*0.1));
      updateUI();return
    }
    rows.push({bricks:[],t:Date.now()});row=rows[rows.length-1];S.stat.tallest=Math.max(S.stat.tallest||0,rows.length);checkTowerMs()
    // Fill the new row
    while(row.bricks.length<bw)row.bricks.push({st:'e'});
    slot=0;
  }
  
  const brick=row.bricks[slot];
  
  if(brick.st==='e'){
    // First tap: position brick above
    brick.st='a';brick.posT=Date.now();
    S.stat.taps=(S.stat.taps||0)+1;
    S.stat.totalClicks=(S.stat.totalClicks||0)+1;
    showFeed(BLD_COL,RES_COL,GOLD_COL,'🔼',slot+'','','');
    earnX('building',1*DB);
  }else if(brick.st==='a'){
    // Second tap: place brick down
    if(!DB_UNLIMITED&&(!(S.mat[mat]||0)||!(S.mat.mortar||0))){notif('Need '+mat+' & mortar!');return}
    if(!DB_UNLIMITED){S.mat[mat]=(S.mat[mat]||0)-1;S.mat.mortar=(S.mat.mortar||0)-1}
    brick.st='d';brick.doneT=Date.now();
    S.stat.taps=(S.stat.taps||0)+1;
    S.stat.totalClicks=(S.stat.totalClicks||0)+1;
    const tmg=towerMsClaimed('gold');S.stat.gold=(S.stat.gold||0)+Math.floor(Math.random()*3+1)*DB*(tmg>0?2:1);const tmLg=towerMsClaimed('legacy');if(tmLg>0){S.stat.legacy=Math.max(S.stat.legacy||0,Math.floor((S.stat.legacy||0)+Math.random()*0.5*tmLg));}
    earnX('building',2*DB);checkAch();
    showFeed(BLD_COL,RES_COL,GOLD_COL,'+1🧱','+'+(Math.floor(Math.random()*3+1)*DB)+'🪙','+'+2*DB+'🧱XP','+'+(Math.floor(2*DB*0.5))+'⚡XP');
  }
  updateUI();
}

// ─── BUILD BURST ────────────────────────────────────────────────────

let burstTO=null;
let burstBusy=false;
function buildBurst(){
  if(burstBusy)return;
  if(S.tower._coll){notif('💥 Collapsed!');return}
  const b=S.burst;rechargeBurst();
  const ch=b.lchrg||0;if(ch<1){notif('⏳ No burst charges! Wait '+(getBurstCooldown())+'s');return}
  const cost=getBurstCost();
  if(!DB_UNLIMITED&&(S.stat.gold||0)<cost){notif('💰 Need '+cost+' gold for burst!');return}
  const stInit=getStab();
  if(stInit.p<15&&S.tower.rows.length>5){notif('⚠️ Tower too unstable!');return}
  if(!DB_UNLIMITED)S.stat.gold=(S.stat.gold||0)-cost;
  b.lchrg--;b.chrg=b.lchrg;b.last=Date.now();
  burstBusy=true;
  const power=getBurstPower();
  const speed=getBurstSpeed();
  let count=0;
  function next(){
    if(count>=power){burstBusy=false;updateUI();return}
    const st=getStab();
    if(st.p<10&&count>5){burstBusy=false;updateUI();notif('⚠️ Burst stopped - unstable!');return}
    tapBuild();
    count++;
    if(count%5===0)updateUI();
    burstTO=setTimeout(next,speed);
  }
  next();
}

// ─── SKILLS & TALENTS TAP ──────────────────────────────────────────

function tapSkills(){
  const g=Math.max(1,Math.floor(Math.random()*1+0.5))*DB;
  S.stat.gold=(S.stat.gold||0)+Math.floor(g*(1+lP('p7')*0.5)*(tL('ge4')>0?1+tL('ge4')*0.1:1)*(tL('t5')>0?1+tL('t5')*0.15:1));
  S.stat.totalClicks=(S.stat.totalClicks||0)+1;
  earnX('general',DB);
  showFeed(GXP_COL,GOLD_COL,GOLD_COL,'+'+g+'🪙','+'+DB+'⚡XP','🧘 Meditate','');
  updateUI();
}

function tapAscend(){
  S.stat.totalClicks=(S.stat.totalClicks||0)+1;
  // Small chance to find a shard
  if(Math.random()<0.005*DB){S.stat.shards=(S.stat.shards||0)+1;notif('💎 Found a Babel Shard!');earnX('mastery',DB*2)}
  else{S.stat.gold=(S.stat.gold||0)+Math.floor(Math.random()*2+1)*DB}
  showFeed('#70d0ff','#ffd700','#e0d0c0','+'+(Math.floor(Math.random()*5+1)*DB)+'🪙','💎 Meditate','','');
  updateUI();
}

function tapTalents(){
  let g=Math.max(1,Math.floor(Math.random()*2+1))*DB;
  if(tL('t5')>0)g=Math.floor(g*(1+tL('t5')*0.15));
  S.stat.gold=(S.stat.gold||0)+Math.floor(g*(1+lP('p7')*0.5)*(tL('ge4')>0?1+tL('ge4')*0.1:1)*(tL('t5')>0?1+tL('t5')*0.15:1));
  S.stat.totalClicks=(S.stat.totalClicks||0)+1;
  // Small chance to refund a talent purchase (respec shard)
  if(Math.random()<0.02){notif('✨ Insight gained!')}
  showFeed(GOLD_COL,GOLD_COL,GOLD_COL,'+'+g+'🪙','🏛️ Contemplate','','');
  updateUI();
}


// ─── PRESTIGE ──────────────────────────────────────────────────────

function buyPrestige(id){
  const u=PR_UPG.find(x=>x.id===id);if(!u)return;
  const l=lP(u.id);if(l>=u.L)return;
  const c=Math.floor(u.cb*Math.pow(u.cm,l));
  if((S.stat.shards||0)<c)return;
  S.stat.shards=(S.stat.shards||0)-c;
  if(!S.ach)S.ach=[];if(!S.pr)S.pr={};S.pr[id]=(S.pr[id]||0)+1;
  notif('🏛️ '+u.n+' Lv.'+(l+1));updateUI()
}

// ─── UPGRADES & TECH ─────────────────────────────────────────────────

function buyUpg(id){
  const allU=[...UPG_G,...UPG_R,...UPG_S,...UPG_A];const u=allU.find(x=>x.id===id);if(!u)return;
  const l=uL(u.id);if(l>=u.L)return;
  const c=Math.floor(u.c*Math.pow(u.m,l));if((S.stat.gold||0)<c)return;
  S.stat.gold-=c;S.upg[id]=(S.upg[id]||0)+1;
  // Auto upgrades also update S.auto for tick logic
  if(UPG_A.find(x=>x.id===id)){S.auto[u.sk]=(S.auto[u.sk]||0)+1}
  notif('🔧 '+u.n+' Lv.'+(l+1));updateUI()
}

function buyTech(id){
  const t=TECH.find(x=>x.id===id);if(!t)return;
  if(S.tech[id]){notif('Already owned');return}
  if((S.stat.gold||0)<t.cost)return;
  S.stat.gold-=t.cost;S.tech[id]=t.val;
  notif('⬆️ '+t.n);updateUI()
}
function buyMs(skill,i){
  if(msG(skill)!==i)return;
  if(S.ms[skill]>=i+1)return;
  const track=MS[skill];
  if(i>=track.length)return;
  if(skLv(skill)<track[i].lv)return;
  S.ms[skill]=i+1;
  notif('🏆 '+track[i].n+'!');updateUI()
}
function buyTalent(id){
  const t=TALENTS.find(x=>x.id===id);if(!t)return;
  const l=tL(t.id);if(l>=t.L)return;
  const rs=t.rS||'general';const rl=t.rL+(t.rS2||0)*l;
  if(skLv(rs)<rl){notif('Need '+rs+' Lv'+rl);return}
  const c=Math.floor(t.cb*Math.pow(t.cm,l));
  if((S.stat.gold||0)<c)return;
  S.stat.gold-=c;S.tal[id]=(S.tal[id]||0)+1;
  notif('🏰 '+t.n+' Lv.'+(l+1));updateUI()
}

// ─── HOLD-TO-REPEAT (multi-tap) ────────────────────────────────────────

let htInt=null;
function htrStart(fn){
  if(htInt)return;
  fn();
  htInt=setInterval(fn,120);
}
function htrStop(){
  if(htInt){clearInterval(htInt);htInt=null}
}
document.addEventListener('mouseup',()=>htrStop());
document.addEventListener('touchend',()=>htrStop());
document.addEventListener('touchcancel',()=>htrStop());

// ─── FEEDBACK ─────────────────────────────────────────────────────────

function showFeed(col1,col2,col3,t1,t2,t3,t4){
  const zone=document.querySelector('.pane.on');
  if(!zone)return;
  const f=document.createElement('div');f.className='feed';
  f.innerHTML='<span class="l1"><span style="color:'+col2+'">'+t1+'</span> <span style="color:'+col3+'">'+t2+'</span></span><span class="l2"><span style="color:'+col1+'">'+t3+'</span> <span style="color:'+GXP_COL+'">'+t4+'</span></span>';
  const r=zone.getBoundingClientRect();
  const lx=Math.max(0,Math.min(r.width-80,lastTapX-r.left+(Math.random()-0.5)*100));
  const ly=Math.max(0,Math.min(r.height-30,lastTapY-r.top+(Math.random()-0.5)*100-20));
  f.style.left=lx+'px';f.style.top=ly+'px';
  zone.appendChild(f);setTimeout(()=>f.remove(),800)
}

function notif(msg){const n=document.getElementById('notif');n.textContent=msg;n.classList.add('sh');clearTimeout(n._to);n._to=setTimeout(()=>n.classList.remove('sh'),1500)}

// ─── CANVAS ───────────────────────────────────────────────────────────

const ca=document.getElementById('bc'),cx=ca.getContext('2d');let cW=0,cH=0,rP=false;
function rC2(){const p=document.getElementById('build-pane'),r=p.getBoundingClientRect();if(r.w<10||r.h<10){rP=true;return}
  const d=window.devicePixelRatio||1;ca.width=r.width*d;ca.height=r.height*d;cW=r.width;cH=r.height;ca.style.width=r.width+'px';ca.style.height=r.height+'px';rP=false}
function draw(){
  const d=window.devicePixelRatio||1;cx.setTransform(d,0,0,d,0,0);
  if(cW<20||cH<20){if(rP||cW<20)rC2();if(cW<20||cH<20)return}
  const w=cW,h=cH,now=Date.now();
  
  // ── Sky background ──
  const rowCount=S.tower.rows.length;
  const skyH=Math.min(0.6,0.3+rowCount*0.003);
  const g=cx.createLinearGradient(0,0,0,h);
  g.addColorStop(0,'#060302');g.addColorStop(skyH,'#0a0604');g.addColorStop(1,'#120a06');
  cx.fillStyle=g;cx.fillRect(0,0,w,h);
  
  // ── Stars ──
  if(rowCount>5){cx.fillStyle='rgba(255,255,240,0.08)';
    for(let i=0;i<20+rowCount;i++){const x=(i*131+now*0.001)%w,y=(i*89+11)%(h*skyH);
      cx.beginPath();cx.arc(x,y,0.3+Math.sin(i+now*0.002)*0.2,0,Math.PI*2);cx.fill()}}
  
  // ── Ground ──
  cx.fillStyle='#0a0604';cx.fillRect(0,h-24,w,24);
  cx.fillStyle='#1a0e08';cx.fillRect(0,h-24,w,1.2);
  cx.fillStyle='rgba(20,12,8,0.3)';cx.fillRect(0,h-20,w,16);
  
  // ── Empty state ──
  const rows=S.tower.rows,bw=getBaseW();
  if(!rows||!rows.length){cx.fillStyle='rgba(255,255,255,0.04)';cx.font='14px sans-serif';cx.textAlign='center';cx.fillText('Tap to start!',w/2,h/2-10);return}
  
  const maxDrawH=h-28,totalSlots=Math.max(rows.length,5);
  const bH=Math.min(10,Math.max(3.5,(maxDrawH/totalSlots)*0.55)),gap=1,mH=Math.max(0.8,bH*0.18),rowH=bH+mH;
  const bW=Math.min(28,Math.max(6,(w-20)/(bw+0.5)));const wallW=bw*bW+(bw-1)*gap,ox=(w-wallW)/2;
  const pW=Math.max(2,bW*0.4); // pillar width
  const cols=BC[getMatId()]||BC.mudBrick,mCols=BC.mortar;
  const st=getStab();
  
  // ── Tower sway ──
  const swayAmt=st.p<30?(30-st.p)*0.008:0;
  const sway=swayAmt*Math.sin(now/300+rowCount*0.1)*Math.min(1,rowCount/20);
  
  // ── Ground shadow ──
  cx.fillStyle='rgba(0,0,0,0.3)';cx.beginPath();
  cx.ellipse(w/2+sway*5,h-24,wallW/2+8,4,0,0,Math.PI*2);cx.fill();
  
  cx.save();cx.translate(sway,0);
  
  // ── Draw pillars on sides ──
  const pillarCol='#3a2a1a';
  for(let ri=Math.max(0,rows.length-Math.floor(maxDrawH/rowH));ri<rows.length;ri++){
    const y=h-26-(ri+1)*rowH;if(y<-rowH||y>h)continue;
    const rowAge=now-(rows[ri].t||0);
    const animT=Math.min(1,rowAge/400);
    if(animT<=0)continue;
    const animScale=0.3+0.7*animT;
    const pY=y+(bH+mH)*(1-animScale);
    const pH=bH*animScale;
    if(pH<1)continue;
    // Left pillar
    cx.fillStyle=pillarCol;cx.fillRect(ox-pW-1,pY,pW,pH);
    cx.fillStyle='rgba(60,50,30,0.3)';cx.fillRect(ox-pW-1,pY,1,pH);
    // Right pillar
    cx.fillStyle=pillarCol;cx.fillRect(ox+wallW+1,pY,pW,pH);
    cx.fillStyle='rgba(60,50,30,0.3)';cx.fillRect(ox+wallW+1+pW-1,pY,1,pH);
  }
  
  // ── Draw rows ──
  const startRow=Math.max(0,rows.length-Math.floor(maxDrawH/rowH));
  for(let ri=startRow;ri<rows.length;ri++){
    const row=rows[ri],y=h-26-(ri+1)*rowH;if(y<-rowH||y>h)continue;
    const rowAge=now-(row.t||0);
    const animT=Math.min(1,rowAge/400);
    if(animT<=0)continue;
    const animScale=0.3+0.7*animT;
    const rY=y+(bH+mH)*(1-animScale);
    const rH=bH*animScale;
    if(rH<1)continue;
    
    // Row highlight for newest row
    const isNew=ri===rows.length-1&&rowAge<800;
    if(isNew){cx.fillStyle='rgba(232,200,122,'+(0.06*(1-rowAge/800))+')';cx.fillRect(ox-1,rY-1,wallW+2,rH+2)}
    
    // Draw each brick
    for(let b=0;b<bw;b++){
      const bx=ox+b*(bW+gap);if(bx+bW<0||bx>w)continue;
      const brick=row.bricks[b]||{st:'e'};
      if(brick.st==='a'){
        // Hovering above - bobbing animation
        const bob=Math.sin(now/200+b*0.5)*2;
        const aY=rY-bH*1.2+bob;
        const g2=cx.createLinearGradient(bx,aY,bx,aY+bH);
        g2.addColorStop(0,'rgba(180,150,120,0.6)');g2.addColorStop(0.5,'rgba(140,110,80,0.7)');g2.addColorStop(1,'rgba(100,80,60,0.6)');
        cx.fillStyle=g2;cx.fillRect(bx,aY,bW,bH);
        cx.strokeStyle='rgba(232,200,122,0.3)';cx.lineWidth=0.5;cx.strokeRect(bx,aY,bW,bH);
        // Drop shadow
        cx.fillStyle='rgba(0,0,0,0.2)';cx.beginPath();
        cx.ellipse(bx+bW/2,rY+bH,Math.min(6,bW*0.3),2,0,0,Math.PI*2);cx.fill();
        // Arrow indicator
        cx.fillStyle='rgba(232,200,122,0.4)';cx.font='6px sans-serif';cx.textAlign='center';
        cx.fillText('👆',bx+bW/2,aY-2);
      }else if(brick.st==='d'){
        
        // Cracked bricks
        if(st.p<25&&(b+ri)%3===0){
          const crackIntensity=Math.max(0,Math.min(1,(25-st.p)/25));
          if(crackIntensity>0.05){
            const pulse=Math.sin(now/200+b+ri)*0.3+0.7;
            const alpha=crackIntensity*0.4*pulse;
            cx.strokeStyle='rgba(200,50,50,'+alpha+')';cx.lineWidth=0.4;
            cx.beginPath();cx.moveTo(bx+1,bY+1);cx.lineTo(bx+bW-1,bY+bHt-1);
            cx.moveTo(bx+bW-1,bY+1);cx.lineTo(bx+1,bY+bHt-1);cx.stroke();
            // Glow on cracks
            if(crackIntensity>0.3){cx.fillStyle='rgba(200,50,50,'+(alpha*0.3)+')';
              cx.beginPath();cx.arc(bx+bW/2,bY+bHt/2,1.5,0,Math.PI*2);cx.fill()}
          }
        }
      }else{
        cx.strokeStyle='rgba(255,255,255,0.02)';cx.lineWidth=0.2;cx.strokeRect(bx,rY,bW,rH)
      }
    }
    // Mortar between rows
    if(ri<rows.length-1){cx.fillStyle=mCols.m;cx.fillRect(ox,rY+rH,wallW,mH)}
  }
  
  // ── Height tier decorations ──
  if(rowCount>=20){const decY=h-26-20*rowH;
    cx.fillStyle='rgba(180,160,120,0.08)';cx.fillRect(ox-3,decY,wallW+6,2);
    for(let b=0;b<bw;b++){if(b%2===0){const dx=ox+b*(bW+gap);
      cx.fillStyle='rgba(200,180,140,0.05)';cx.fillRect(dx+bW*0.2,decY-rowH*0.5,bW*0.6,rowH*0.5)}}}
  if(rowCount>=50){const dec2Y=h-26-50*rowH;
    cx.fillStyle='rgba(200,180,140,0.12)';cx.fillRect(ox-4,dec2Y,wallW+8,3);
    for(let b=1;b<bw-1;b+=2){const dx=ox+b*(bW+gap);
      cx.fillStyle='rgba(232,200,122,0.06)';cx.fillRect(dx+bW*0.15,dec2Y-rowH-1,bW*0.7,rowH*1.5)}}
  
  // ── Foundation line ──
  cx.fillStyle='#2a1508';cx.fillRect(ox-3,h-26,wallW+6,3);
  cx.fillStyle='rgba(60,40,20,0.3)';cx.fillRect(ox-pW-3,h-26,pW,3);
  cx.fillStyle='rgba(60,40,20,0.3)';cx.fillRect(ox+wallW+3-pW,h-26,pW,3);
  
  cx.restore(); // end sway translate
  
  // ── Low stability visual effects ──
  if(st.p<20){
    const sw=swayAmt*5*Math.sin(now/350);
    cx.save();cx.translate(sw,0);
    cx.fillStyle='rgba(200,100,50,'+((20-st.p)/20*0.06)+')';
    cx.fillRect(ox-2,h-26-wallW*0.12,wallW+4,24);
    cx.restore()
  }
  
  // ── Collapse particles ──
  if(S.tower._coll){const t=now*0.003;const pCols=['#cc5050','#e8a050','#c46a3a','#e8c87a'];
    for(let i=0;i<30;i++){const a=(i*97+t)%(Math.PI*2);const r=3+((i*53+t*2)%(60+rowCount));
      const size=1+Math.sin(i*2.7+t)*2;
      cx.fillStyle=pCols[i%4];cx.globalAlpha=0.25+Math.sin(i*1.3+t*0.5)*0.2;
      cx.beginPath();cx.arc(w/2+Math.cos(a)*r,h*0.3+Math.sin(a*1.5)*r*0.4+Math.sin(i+t)*8,size,0,Math.PI*2);cx.fill()}
    cx.globalAlpha=1}
}

// ─── HUD ──────────────────────────────────────────────────────────────

function updateHUD(){
  const h=S.tower.rows.length;const s=getStab();
  const hMs=TOWER_MS.filter(m=>h>=m.h).length;const nextHMs=TOWER_MS.find(m=>h<m.h);
  document.getElementById('bhud-progress').textContent='H:'+h+' W:'+getBaseW()+' ☁️'+s.m.toFixed(1)+(hMs?(' 🏅'+hMs):'')+(nextHMs?' →'+nextHMs.h:' MAX');
  const f=document.getElementById('stab-fill');f.style.width=Math.max(0,Math.min(100,s.p))+'%';
  f.style.background=s.p>50?'#40a040':s.p>20?'#c0a040':s.p>5?'#c06030':'#cc2020';
  const rows=S.tower.rows,bw=getBaseW();
  if(rows&&rows.length){const row=rows[rows.length-1];
    document.getElementById('bhud-row').innerHTML=row.bricks.map((b,i)=>{let c='dot'+(b.st==='d'?' done':'');if(s.p<10&&b.st==='d'&&(i+rows.length)%3===0)c+=' crack';return '<span class="'+c+'"></span>'}).join('')}
  else document.getElementById('bhud-row').innerHTML='';

    const bch=S.burst;rechargeBurst();const bEl=document.getElementById("bhud-burst");if(bEl){const bMax=getBurstCharges();const bCd=getBurstCooldown();const bSince=Date.now()-(bch.last||0);const bLeft=Math.max(0,bCd*1000-bSince);bEl.innerHTML="⚡ "+(bch.lchrg||0)+"/"+bMax+" charges"+(bch.lchrg<bMax?" ("+Math.ceil(bLeft/1000)+"s)":" ✅");}
  document.getElementById("bhud-action").innerHTML=S.tower._coll?"💥 Rebuild!":rows.length?"👉 Tap to add row":"👉 Tap to start!";
  document.getElementById("build-sub").textContent=S.tower._coll?"💥 Collapsed! Tap to rebuild":rows.length?"Row "+(S.tower.rows.length)+" · ×100 burst":"Tap to start building!";
}

// ─── RENDER UI ────────────────────────────────────────────────────────

function updateUI(){
  updateXPBars();
  const goldEl=document.getElementById('st-gold');
  const oldVal=goldEl._lastVal||0;const newVal=S.stat.gold||0;
  if(oldVal!==newVal){goldEl._lastVal=newVal;goldEl._animStart=performance.now();goldEl._animFrom=oldVal}
  if(goldEl._animStart){const t=Math.min(1,(performance.now()-goldEl._animStart)/200);const cur=Math.floor(goldEl._animFrom+(newVal-goldEl._animFrom)*t);goldEl.textContent=fmt(cur);if(t>=1)goldEl._animStart=0}else goldEl.textContent=fmt(newVal);
  const dbi=document.getElementById('db-indicator');if(dbi){dbi.textContent=DB>1?'🔬×'+DB:'';dbi.style.cursor='pointer';dbi.onclick=()=>G.toggleDB()}
  const uli=document.getElementById('ul-indicator');if(uli){uli.textContent=DB_UNLIMITED?'♾️':'·';uli.style.cursor='pointer';uli.onclick=()=>G.toggleUL()}
  let tc=0;Object.values(S.mat).forEach(v=>tc+=v);document.getElementById('st-bricks').textContent=fmt(tc);
  document.getElementById('st-hgt').textContent=S.tower.rows.length;
  const ae=document.getElementById('st-auto');if(ae){const acts=[['⛏',aL('gather')],['🔨',aL('craft')],['🧱',aL('build')]].filter(x=>x[1]>0).map(x=>x[0]);ae.textContent=acts.length?'⚙'+acts.join(''):''}
  document.getElementById('stat-clicks').textContent=fmt(S.stat.totalClicks||0);
  document.getElementById('stat-tallest').textContent=fmt(S.stat.tallest||0);
  document.getElementById('stat-collapses').textContent=fmt(S.tower.collapses||0);
  document.getElementById('stat-legacy').textContent=(S.stat.legacy||0)+'%';
  document.getElementById('stat-taps').textContent=fmt(S.stat.taps||0);

  // Resource grid
  const resHtml=unlockedRes().map(r=>{
    const amt=S.res[r.id]||0;
    const isActive=gF()&&gF().id===r.id;
    return '<div class="r'+(isActive?' glow':'')+'"><span class="i">'+r.i+'</span><span class="n">'+r.n+'</span><span class="v">'+fmt(amt)+'</span></div>'
  }).join('');
  document.getElementById('g-res').innerHTML=resHtml;

  // Gather zone
  const gr=gF();if(gr){
    document.getElementById('g-icon').textContent=gr.i;
    document.getElementById('g-hint').textContent='Tap to gather '+gr.n;
    let perTap=1;perTap+=uL('g1')*1+uL('g2')*2+uL('g3')*4+uL('g4')*8;
    let rBonus=0;UPG_R.forEach(u=>{const l=uL(u.id);if(l>0)rBonus+=u.v*l});
    const eff=Math.max(1,Math.floor(1*(1+rBonus)));
    document.getElementById('g-sub').textContent='+'+eff+'R +'+perTap+'🪙 per tap';
  }

  // Gather TAP upgrades
  document.getElementById('g-upgs').innerHTML=
    '<div class="uh">💰 Tap Upgrades</div>'+
    UPG_G.filter(u=>u.sk==='gather').map(u=>{
      const l=uL(u.id),mx=l>=u.L,c=Math.floor(u.c*Math.pow(u.m,l));const ok=(S.stat.gold||0)>=c&&!mx;
      return '<div class="u"><div class="d"><div class="nm">'+u.n+(mx?' ✅':l>0?' Lv.'+l:'')+'</div><div class="dc">'+u.d+'</div></div><span class="co">🪙'+fmt(c)+'</span><button onclick="G.buyUpg(\''+u.id+'\')"'+(ok?'':'disabled')+'>'+(mx?'MAX':'Buy')+'</button></div>'
    }).join('')+
    '<div class="uh">🪨 Resource Upgrades</div>'+
    UPG_R.map(u=>{
      const l=uL(u.id),mx=l>=u.L,c=Math.floor(u.c*Math.pow(u.m,l));const ok=(S.stat.gold||0)>=c&&!mx;
      return '<div class="u"><div class="d"><div class="nm">'+u.n+(mx?' ✅':l>0?' Lv.'+l:'')+'</div><div class="dc">'+u.d+'</div></div><span class="co">🪙'+fmt(c)+'</span><button onclick="G.buyUpg(\''+u.id+'\')"'+(ok?'':'disabled')+'>'+(mx?'MAX':'Buy')+'</button></div>'
    }).join('');

  // Gather AUTO upgrades
  const gatherAuto=UPG_A.filter(u=>u.sk==='gather');
  const hasGatherAuto=gatherAuto.some(u=>uL(u.id)>0);
  document.getElementById('g-auto-upgs').innerHTML=
    '<div class="uh">⚙️ Automation</div>'+
    gatherAuto.map(u=>{
      const l=uL(u.id),mx=l>=u.L,c=Math.floor(u.c*Math.pow(u.m,l));const ok=(S.stat.gold||0)>=c&&!mx;
      return '<div class="u"><div class="d"><div class="nm">🤖 '+u.n+(mx?' ✅':l>0?' Lv.'+l:'')+'</div><div class="dc">'+u.d+(' ⏱'+Math.round(getAutoInterval(u.sk)/1000*10)/10+'s')+'</div></div><span class="co">🪙'+fmt(c)+'</span><button onclick="G.buyUpg(\''+u.id+'\')"'+(ok?'':'disabled')+'>'+(mx?'MAX':'Buy')+'</button></div>'
    }).join('');

  // Craft pane
  const mats=unlockedMat();
  document.getElementById('c-recipes').innerHTML=mats.length?'<div class="cr">'+
    mats.map(m=>{
      const canCraft=Object.entries(m.r).every(([k,v])=>(S.res[k]||0)>=v);
      const sel=S._selCraft===m.id;
      return '<div class="ci'+(sel?' on':'')+(canCraft?'':' locked')+'" onclick="G.selCraft(\''+m.id+'\')"><div>'+m.i+'</div><div class="cn">'+m.n+'</div><div class="cn">⏱'+m.t+' 🪙'+m.t+'</div></div>'
    }).join('')+'</div>':'<div class="ch">🔓 Unlock more resources to craft</div>';
  const ac=autoCraft();
  if(ac){
    document.getElementById('c-icon').textContent=ac.i;
    document.getElementById('c-hint').textContent='Tap to craft '+ac.n;
    document.getElementById('c-sub').textContent=ac.d+' · '+Object.entries(ac.r).map(([k,v])=>RES_ALL.find(r=>r.id===k)?.i+v+' '+RES_ALL.find(r=>r.id===k)?.n).join(' + ');
  }else{
    document.getElementById('c-hint').textContent='Need resources';
    document.getElementById('c-sub').textContent='Tap Gather tab to collect materials';
  }
  const cbar=document.getElementById('c-bar');const cfill=document.getElementById('c-fill');
  const cac=autoCraft();
  if(cac&&cbar){cbar.style.display='block';const ct=aL('craft')>0?getAutoInterval('craft')/100:(cac.t||4);const pct=Math.min(100,Math.floor((S.autoCraftTick||0)/ct*100));cfill.style.width=pct+'%'}
  else if(cbar)cbar.style.display='none';

  // Craft TAP upgrades
  document.getElementById('c-upgs').innerHTML=
    '<div class="uh">💰 Tap Upgrades</div>'+
    UPG_G.filter(u=>u.sk==='craft').map(u=>{
      const l=uL(u.id),mx=l>=u.L,c=Math.floor(u.c*Math.pow(u.m,l));const ok=(S.stat.gold||0)>=c&&!mx;
      return '<div class="u"><div class="d"><div class="nm">'+u.n+(mx?' ✅':l>0?' Lv.'+l:'')+'</div><div class="dc">'+u.d+'</div></div><span class="co">🪙'+fmt(c)+'</span><button onclick="G.buyUpg(\''+u.id+'\')"'+(ok?'':'disabled')+'>'+(mx?'MAX':'Buy')+'</button></div>'
    }).join('');

  // Craft AUTO upgrades
  const craftAuto=UPG_A.filter(u=>u.sk==='craft');
  document.getElementById('c-auto-upgs').innerHTML=
    '<div class="uh">⚙️ Automation</div>'+
    craftAuto.map(u=>{
      const l=uL(u.id),mx=l>=u.L,c=Math.floor(u.c*Math.pow(u.m,l));const ok=(S.stat.gold||0)>=c&&!mx;
      return '<div class="u"><div class="d"><div class="nm">🤖 '+u.n+(mx?' ✅':l>0?' Lv.'+l:'')+'</div><div class="dc">'+u.d+(' ⏱'+Math.round(getAutoInterval(u.sk)/1000*10)/10+'s')+'</div></div><span class="co">🪙'+fmt(c)+'</span><button onclick="G.buyUpg(\''+u.id+'\')"'+(ok?'':'disabled')+'>'+(mx?'MAX':'Buy')+'</button></div>'
    }).join('');

  // Tech panel
  (function(){const gs=[{n:'📐 Width',t:'w',u:TECH.filter(x=>x.t==='w')},{n:'🛡️ Reinforce',t:'r',u:TECH.filter(x=>x.t==='r')},{n:'🏛️ Foundation',t:'f',u:TECH.filter(x=>x.t==='f')}];
  const tp=document.getElementById('ttech-panel');
  tp.innerHTML=gs.map(g=>'<div class="tuh">'+g.n+'</div>'+g.u.map(function(ti){const o=S.tech[ti.id];
    const r=(S.stat.gold||0)>=ti.cost;var q=String.fromCharCode(39);return '<div class="tu"><div class="td"><div class="tnm">'+ti.n+'</div><div class="tdc">'+ti.d+'</div></div><span class="tco">ðª'+fmt(ti.cost)+'</span><button onclick='+q+'G.buyTech(\''+ti.id+'\')'+q+(o?'disabled':r?'':'disabled')+'>'+(o?'OWNED':'Buy')+'</button></div>'}).join('')).join('')})();
  updateHUD();
  updateSkillsUI();
}

function getAutoInterval(id){const l=Math.min(aL(id),15);return Math.max(100,3000/(1+l*0.5));}

function runAuto(){
  if(S.tick<1)return // skip tick 0 to avoid instant burst on load
  // Auto-gather
  const prAuto=lP('p5');if(aL('gather')+prAuto>0&&S.tick>1){
    const gi=getAutoInterval('gather');
    if(S.tick%(gi/100)<1){
      const gr=gF();if(gr){const ga4l=tL('ga4');if(ga4l>0){for(let i=0;i<Math.floor(1+ga4l*0.15);i++)gather(gr.id);}else gather(gr.id);}
    }
  }
  // Auto-craft
  if(aL('craft')+prAuto>0){
    const ci=getAutoInterval('craft');
    if(aL('craft')+prAuto>0){S.autoCraftTick=(S.autoCraftTick||0)+1;const ci2=getAutoInterval('craft');if(S.autoCraftTick>=ci2/100){S.autoCraftTick=0;const s=autoCraft();if(s){const cr4l=tL('cr4');if(cr4l>0){for(let i=0;i<Math.floor(1+cr4l*0.15);i++)craft(s)}else craft(s)}}}
  }
  // Auto-build
  if(aL('build')+prAuto>0){
    const bi=getAutoInterval('build');
    if(S.tick%(bi/100)<1){
      const mat=getMatId();
      if(mat&&(S.mat[mat]||0)>0&&(S.mat.mortar||0)>0){
        tapBuild();
      }
    }
  }
}


function renderBurstUpgrades(){
  const p=document.getElementById('burst-panel');
  if(!p)return;
  const ch=S.burst;rechargeBurst();
  const maxCh=getBurstCharges();
  const cd=getBurstCooldown();
  const since=Date.now()-(ch.last||0);
  const cdLeft=Math.max(0,cd*1000-since);
  const nextCharge=ch.lchrg<maxCh?Math.ceil(cdLeft/1000)+'s':'Full';
  let html='<div style="font-size:10px;color:#e8c87a;font-weight:700;margin-bottom:3px">⚡ BURST ENGINE</div>';
  html+='<div style="font-size:9px;color:#8a7a6a;margin-bottom:4px;display:flex;gap:6px">Charges: <span style="color:#70d0ff">'+ch.lchrg+'/'+maxCh+'</span> Next: <span style="color:#c0a070">'+nextCharge+'</span></div>';
  BURST_UPG.forEach(u=>{
    const l=S.upg[u.id]||0;const mx=l>=u.L;
    const c=Math.floor(u.cb*Math.pow(u.cm||2.5,l));
    const ok=!mx&&(S.stat.gold||0)>=c&&!(S.tower._coll);
    const v=u.id==='bp'?20+Math.min(l,u.L||10)*20:
           u.id==='bs'?50-Math.min(l,u.L||8)*5:
           u.id==='bc'?20-Math.min(l,u.L||10)*2:
           u.id==='bcd'?20-Math.min(l,u.L||9)*2:
           u.id==='bch'?1+Math.min(l,u.L||5):0;
    const nv=u.id==='bp'?20+Math.min(l+1,u.L||10)*20:
             u.id==='bs'?50-Math.min(l+1,u.L||8)*5:
             u.id==='bc'?20-Math.min(l+1,u.L||10)*2:
             u.id==='bcd'?20-Math.min(l+1,u.L||9)*2:
             u.id==='bch'?1+Math.min(l+1,u.L||5):0;
    html+='<div class="tu"><div class="td"><div class="tnm">'+u.i+' '+u.n+(mx?' ✅':l>0?' Lv.'+l:'')+'</div><div class="tdc">'+u.d+'</div><div class="tdc" style="color:#6a8a6a">'+(u.id==='bp'?'Pwr: '+v+'→'+nv:u.id==='bs'?'Spd: '+v+'ms→'+nv+'ms':u.id==='bc'?'Cost: '+v+'🪙→'+nv:u.id==='bcd'?'CD: '+v+'s→'+nv+'s':u.id==='bch'?'Chrg: '+v+'→'+nv:'')+'</div></div><span class="tco">🪙'+fmt(c)+'</span><button onclick="G.burstBuyUpg('+u.id+')"'+(ok?'':' disabled')+'>'+(mx?'MAX':'Buy')+'</button></div>'
  });
  p.innerHTML=html;
}function updateSkillsUI(){
  const si={gathering:'⛏️',crafting:'🔨',building:'🧱',general:'⚡',mastery:'👑'};
  const sc={'gathering':GAT_COL,'crafting':CRA_COL,'building':BLD_COL,'general':GXP_COL,'mastery':'#d070d0'};
  document.getElementById('skills-list').innerHTML=Object.entries(S.sk).map(([id,s])=>{
    const nx=xpN(s.lv);const pct=Math.min(100,Math.floor((s.xp||0)/nx*100));
    return '<div class="sk"><div class="shdr"><span class="sn" style="color:'+sc[id]+'">'+(si[id]||'')+' '+id.charAt(0).toUpperCase()+id.slice(1)+'</span><span class="sl" style="color:'+sc[id]+'">Lv.'+s.lv+'</span></div>'+
      '<div class="sbar"><div class="sf" style="width:'+pct+'%;background:'+sc[id]+'"></div></div><div class="sxp">'+(s.xp||0)+'/'+nx+' ('+(nx-(s.xp||0))+' to next)</div></div>'
  }).join('');

  const msKeys=['gathering','crafting','building','general','mastery'];
  const msIcons={'gathering':'⛏️','crafting':'🔨','building':'🧱','general':'⚡','mastery':'👑'};
  const msCols={'gathering':GAT_COL,'crafting':CRA_COL,'building':BLD_COL,'general':GXP_COL,'mastery':'#d070d0'};
  document.getElementById('milestones-area').innerHTML=msKeys.map(skill=>{
    const track=MS[skill];const claimed=msG(skill);
    let html='<div class="ms-sec"><div class="msh"><span style="color:'+msCols[skill]+'">'+msIcons[skill]+' '+skill.charAt(0).toUpperCase()+skill.slice(1)+'</span><span>'+claimed+'/'+track.length+'</span></div><div class="msg">';
    track.forEach((m,i)=>{const un=i<claimed;const isN=i===claimed;const isN2=i===claimed+1;
      if(i>claimed+1&&!un)return;
      const canClaim=isN&&skLv(skill)>=m.lv;
      html+='<div class="m'+(un?' unlocked':'')+(isN||isN2?' next':'')+'" '+(canClaim?'onclick="G.buyMs(\''+skill+'\','+i+')" style="cursor:pointer"':'')+'>'+
        '<div class="ml">'+(un?'✅':'🔒')+'Lv'+m.lv+'</div><div class="md">'+(un?m.n:isN?(canClaim?'Claim!':'Lv'+m.lv+' req'):'')+'</div>'+(un?'<div class="mb">✅</div>':'')+'</div>';
    });html+='</div></div>';return html;
  }).join('');

  const ss=[{n:'⛏️Gathering',u:UPG_S.filter(x=>x.sk==='gathering'),sk:'gathering'},{n:'🔨Crafting',u:UPG_S.filter(x=>x.sk==='crafting'),sk:'crafting'},
    {n:'🧱Building',u:UPG_S.filter(x=>x.sk==='building'),sk:'building'},{n:'⚡General',u:UPG_S.filter(x=>x.sk==='general'),sk:'general'},{n:'👑Mastery',u:UPG_S.filter(x=>x.sk==='mastery'),sk:'mastery'}];
  document.getElementById('skill-upgs-area').innerHTML=ss.map(set=>{
    let h='<h>'+set.n+' <span style="color:#60a060;font-size:10px">(Lv'+skLv(set.sk)+')</span></h>';
    h+=set.u.map(u=>{const l=uL(u.id),mx=l>=u.L,c=Math.floor(u.c*Math.pow(u.m,l));const ok=(S.stat.gold||0)>=c&&!mx,hl=skLv(set.sk)>=u.rL;
      return '<div class="u"><div class="d"><div class="nm">'+u.n+(mx?' ✅':l>0?' Lv.'+l:'')+'</div><div class="dc">'+u.d+' (Lv'+u.rL+')</div></div><span class="co">🪙'+fmt(c)+'</span><button onclick="G.buyUpg(\''+u.id+'\')"'+(ok&&hl?'':'disabled')+'>'+(mx?'MAX':'Buy')+'</button></div>'}).join('');
    return h;
  }).join('');

  document.getElementById('talents-grid').innerHTML=TALENTS.map(t=>{
    const l=tL(t.id),mx=l>=t.L,rs=t.rS||'general',rl=t.rL+(t.rS2||0)*l,hl=skLv(rs)>=rl;const rlStr=t.rS2?'Lv'+t.rL+'+'+t.rS2+'/lv':'Lv'+t.rL;
    const c=Math.floor(t.cb*Math.pow(t.cm,l)),ok=(S.stat.gold||0)>=c&&!mx;
    const e=t.ef(l);const es=Object.entries(e).map(([k,v])=>k+': +'+(typeof v==='number'?Math.round(v*100):v)+'%').join(', ');
    return '<div class="parapet" style="border-color:'+(mx?'#3a5a3a':hl?'#2a180e':'#0a0604')+'"><div class="phdr"><span class="pn">'+t.i+' '+t.n+'</span><span class="pl" style="color:'+(mx?'#60a060':'#8a6a4a')+'">'+(mx?'MAX':'Lv'+l+'/'+t.L)+'</span></div>'+
      '<div class="pdesc">'+t.d+' · '+rs+' '+rlStr+'</div><div class="pbar"><div class="pf" style="width:'+(l/t.L*100)+'%"></div></div><div class="peff">'+es+'</div>'+
      '<button onclick="G.buyTalent(\''+t.id+'\')"'+(ok&&hl?'':'disabled')+'>🪙'+fmt(c)+' '+(mx?'MAXED':l>0?'Upgrade':'Unlock')+'</button></div>'}).join('');

  // Prestige upgrades
  document.getElementById('shard-count').textContent=fmt(S.stat.shards||0);
  document.getElementById('prestige-upgs').innerHTML=PR_UPG.map(u=>{
    const l=lP(u.id),mx=l>=u.L,c=Math.floor(u.cb*Math.pow(u.cm,l)),ok=(S.stat.shards||0)>=c&&!mx;
    return '<div class="u"><div class="d"><div class="nm">'+u.i+' '+u.n+(mx?' ✅':l>0?' Lv.'+l:'')+'</div><div class="dc">'+u.d+'</div></div><span class="co" style="color:#70d0ff">💎'+fmt(c)+'</span><button onclick="G.buyPrestige(\''+u.id+'\')"'+(ok?'':'disabled')+'>'+(mx?'MAX':'Buy')+'</button></div>'
  }).join('');

  updateHUD();
}

function switchTab(t){document.querySelectorAll('.t').forEach(b=>b.classList.remove('on'));document.querySelectorAll('.pane').forEach(p=>p.classList.remove('on'));
  document.querySelector('.t[data-t="'+t+'"]').classList.add('on');document.getElementById(t+'-pane').classList.add('on');
  if(t==='build')requestAnimationFrame(()=>rC2())}
  if(t==='ascend'&&!S.pr)S.pr={};

function save(){try{S.lastSave=Date.now();localStorage.setItem('babel_save',JSON.stringify(S))}catch(e){}}
function load(){try{const d=localStorage.getItem('babel_save');if(d){Object.assign(S,JSON.parse(d));
  if(!S.tech)S.tech={};if(!S.tal)S.tal={};if(!S.ms)S.ms={gathering:0,crafting:0,building:0,general:0};
  if(!S.sk)S.sk={gathering:{xp:0,lv:1},crafting:{xp:0,lv:1},building:{xp:0,lv:1},general:{xp:0,lv:1}};
  if(!S.sk.mastery)S.sk.mastery={xp:0,lv:1};
  if(!S.ms.mastery)S.ms.mastery=0;
  if(!S.tower)S.tower={rows:[],colCount:3,collapses:0};if(!S.tower.rows)S.tower.rows=[];if(S.tower._coll===undefined)S.tower._coll=false;if(!S.tower.lastRowTime)S.tower.lastRowTime=0;
  if(!S._selCraft)S._selCraft=null;if(!S.auto)S.auto={gather:0,craft:0,build:0};if(S.autoCraftTick===undefined)S.autoCraftTick=0;if(typeof S.tower.collapses!=='number')S.tower.collapses=0;if(S.tower.tm===undefined)S.tower.tm=0;if(!S.burst)S.burst={power:20,speed:50,cost:20,cooldown:20,chrg:1,lchrg:1,last:0};if(typeof S.stat.tallest!=='number')S.stat.tallest=0;if(typeof S.stat.legacy!=='number')S.stat.legacy=0;if(typeof S.stat.shards!=='number')S.stat.shards=0;if(typeof S.lastSave!=='number')S.lastSave=0;if(!S.pr)S.pr={};
  // Recalculate all skill levels from XP
  if(S.sk){Object.keys(S.sk).forEach(k=>{if(S.sk[k])rC(k)})}

  // Offline progress
  const now=Date.now();const elapsed=now-(S.lastSave||now);S.lastSave=now;
  const maxOffline=86400000;const ticks=Math.min(elapsed,maxOffline)/100;
  if(ticks>5&&(S.auto.gather||S.auto.craft||S.auto.build)){
    let autoGathers=0,autoCrafts=0,autoBuilds=0;
    if(aL('gather')>0){const gi=getAutoInterval('gather');autoGathers=Math.floor(ticks/(gi/100))}
    const prAuto=lP('p5');if(aL('craft')+prAuto>0){const ci=getAutoInterval('craft');autoCrafts=Math.floor(ticks/(ci/100))}
    if(aL('build')+prAuto>0){const bi=getAutoInterval('build');autoBuilds=Math.floor(ticks/(bi/100))}
    let gains=[];
    if(autoGathers>0){const r=gF();if(r){S.res[r.id]=(S.res[r.id]||0)+autoGathers;S.stat.gold=(S.stat.gold||0)+autoGathers;gains.push('⛏x'+autoGathers)}}
    if(autoCrafts>0){const s=autoCraft();if(s){S.mat[s.id]=(S.mat[s.id]||0)+autoCrafts;S.stat.gold=(S.stat.gold||0)+autoCrafts*2;gains.push('🔨x'+autoCrafts)}}
    if(autoBuilds>0){const mat=getMatId();if(mat&&(S.mat[mat]||0)>=autoBuilds&&(S.mat.mortar||0)>=autoBuilds){S.mat[mat]-=autoBuilds;S.mat.mortar-=autoBuilds;S.tower.rows=[];for(let i=0;i<Math.min(autoBuilds,500);i++){const row={bricks:[],t:Date.now()};for(let j=0;j<getBaseW();j++)row.bricks.push({st:'d'});S.tower.rows.push(row)}gains.push('🧱x'+autoBuilds)}}
    if(gains.length){notif('⚡Offline: '+gains.join(' '));S.stat.tallest=Math.max(S.stat.tallest||0,S.tower.rows.length);updateUI()}
  }
  return true}}catch(e){}return false}

function init(){
  document.querySelectorAll('.t').forEach(b=>b.addEventListener('click',()=>switchTab(b.dataset.t)));
  ['gather-zone','craft-zone','build-tap-overlay'].forEach(id=>{
    const el=document.getElementById(id);
    if(!el)return;
    const fn={'gather-zone':()=>gather(gF().id),'craft-zone':()=>{const s=autoCraft();if(s){S.autoCraftTick=0;craft(s)}},'build-tap-overlay':()=>tapBuild()}[id];
    el.addEventListener('mousedown',()=>htrStart(fn));
    el.addEventListener('touchstart',()=>htrStart(fn),{passive:true});
  });
  // Skills & talents tap zones
  ['skills-tap','talents-tap'].forEach(id=>{
    const el=document.getElementById(id);
    const fn={'skills-tap':()=>G.tapSkills(),'talents-tap':()=>G.tapTalents()}[id];
    if(el){el.addEventListener('mousedown',()=>htrStart(fn));el.addEventListener('touchstart',()=>htrStart(fn),{passive:true})}
  });
  ca.addEventListener('click',()=>tapBuild());
  document.addEventListener('keydown',e=>{if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA')return;
    if(e.key===' '||e.key==='Enter'){e.preventDefault();tapBuild()}
    if(e.key>='1'&&e.key<='6')switchTab(['','gather','craft','build','skills','talents','ascend'][+e.key])});
  if(!load())initTower();
  window.addEventListener('resize',()=>rC2());rC2();updateUI();
  setInterval(()=>{autoTick();runAuto();rechargeBurst();S.tick++;if(S.tick%5===0)updateUI()},100);
  setInterval(save,5000);
  (function lp(){draw();requestAnimationFrame(lp)})();
  checkAch();console.log('🗼 Babel loaded!');
}
window.G={init,gather,craft,tapBuild,buildBurst,tapSkills,tapTalents,tapAscend,buyPrestige,buyUpg,buyTech,selCraft(id){S._selCraft=id;updateUI()},buyMs(s,i){buyMs(s,i)},buyTalent,toggleTech(){document.getElementById('ttech-panel').classList.toggle('sh')},toggleBurst(){const el=document.getElementById('burst-panel');if(el.style.display==='block'){el.style.display='none'}else{el.style.display='block';renderBurstUpgrades()}},
toggleOptions(){document.getElementById('options-panel').classList.toggle('sh')},
toggleDB(){const el=document.getElementById('opt-db');if(el.textContent==='ON'){DB_OFF();el.textContent='OFF';el.classList.add('off')}else{DB_ON();el.textContent='ON';el.classList.remove('off')}updateUI()},
toggleUL(){const el=document.getElementById('opt-ul');if(el.textContent==='ON'){DB_UNLIMITED=false;el.textContent='OFF';el.classList.add('off')}else{DB_UNLIMITED=true;el.textContent='ON';el.classList.remove('off')}updateUI()},
exportSave(){const d=localStorage.getItem('babel_save');if(navigator.clipboard){navigator.clipboard.writeText(d||'');notif('💾 Save copied!')}else{prompt('Copy save:',d||'')}},
resetGame(){if(confirm('Reset everything?')){localStorage.removeItem('babel_save');location.reload()}},burstBuyUpg,renderBurstUpgrades};
})();
document.addEventListener('DOMContentLoaded',()=>{G.init()});
</script>
</body>
</html>
