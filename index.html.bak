      </div></div>
    </div>
  </div>
  <div id="tabs">
    <button class="t on" data-t="gather">⛏️ Gather</button>
    <button class="t" data-t="craft">🔨 Craft</button>
    <button class="t" data-t="build">🗼 Build</button>
    <button class="t" data-t="skills">⚡ Skills</button>
    <button class="t" data-t="talents">🏰 Talents</button>
    <button class="t" data-t="ascend">🏛️ Ascend</button>
  </div>
  <div id="content">
    <div class="pane on" id="gather-pane">
      <div class="pane-body">
        <div class="g-res" id="g-res"></div>
        <div class="g-upgs" id="g-upgs"></div>
        <div class="a-upgs" id="g-auto-upgs"></div>
      </div>
      <div class="tz" id="gather-zone">
        <div class="tz-icon" id="g-icon">🟤</div>
        <div class="tz-hint" id="g-hint">Tap to gather Mud</div>
        <div class="tz-sub" id="g-sub">+1 per tap</div>
      </div>
    </div>
    <div class="pane" id="craft-pane">
      <div class="pane-body">
        <div class="c-recipes" id="c-recipes" style="margin-top:2px"></div>
        <div class="c-upgs" id="c-upgs"></div>
        <div class="a-upgs" id="c-auto-upgs"></div>
      </div>
      <div class="tz" id="craft-zone">
        <div class="tz-icon" id="c-icon">🧱</div>
        <div class="tz-hint" id="c-hint">Tap to craft</div>
        <div class="tz-sub" id="c-sub">Select a recipe</div>
        <div class="cbar" id="c-bar" style="display:none"><div class="cf" id="c-fill" style="width:0%"></div></div>
      </div>
    </div>
    <div class="pane" id="build-pane">
      <canvas id="bc"></canvas>
      <div class="tz" id="build-tap-overlay" onclick="G.buildBurst()">
        <span class="tz-icon" style="font-size:24px">🧱</span>
        <span class="tz-hint" style="font-size:14px">Tap to build</span>
        <span class="tz-sub" style="font-size:10px" id="build-sub">Place a row</span>
      </div>
      <div id="tower-tech"><button onclick="G.toggleTech()">⬆️</button><span style="color:#5a8a3a;font-size:9px;margin-left:4px">×100</span></div>
      <div id="burst-panel" style="display:none;position:absolute;top:130px;left:4px;right:4px;z-index:7;background:rgba(10,6,4,0.96);border:1px solid #2a180e;border-radius:5px;padding:5px;backdrop-filter:blur(4px);max-height:50%;overflow-y:auto"></div>
      <div id="ttech-panel"></div>
      <div class="bhud">
        <div class="sn" id="bhud-name">🗼 Tower of Babel</div>
        <div class="pt" id="bhud-progress">H:0 W:3</div>
        <div class="stab" id="stab-bar"><div class="sf" id="stab-fill" style="width:100%;background:#40a040"></div></div>
        <div style="display:flex;gap:6px;align-items:center"><span id="ach-badge" style="font-size:10px;color:#d070d0;cursor:pointer" onclick="G.showAch()">🏆</span><span style="font-size:10px;color:#6a5a4a;cursor:pointer" onclick="G.toggleTech()">⚙️Tech</span><span style="font-size:10px;color:#6a5a4a;cursor:pointer" onclick="G.toggleBurst()">⚡Burst</span></div><div class="ah" id="bhud-burst">⚡ Burst: 1/1 charge</div>
        <div class="ah" id="bhud-action">👉 Tap </div>
        <div class="row" id="bhud-row"></div>
      </div>
    </div>
    <div class="pane" id="skills-pane">
      <div class="pane-body sk-scroll">
        <div id="stats-display" style="display:grid;grid-template-columns:repeat(2,1fr);gap:2px;margin-bottom:4px">
          <div style="background:rgba(15,10,6,0.5);border:1px solid #1a0e08;border-radius:4px;padding:3px 5px;text-align:center">
            <div style="font-size:9px;color:#8a7a6a">👆 Total Clicks</div>
            <div style="font-size:14px;font-weight:700;color:#e8ddd0" id="stat-clicks">0</div>
          </div>
          <div style="background:rgba(15,10,6,0.5);border:1px solid #1a0e08;border-radius:4px;padding:3px 5px;text-align:center">
