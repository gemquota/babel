          <div style="background:rgba(15,10,6,0.5);border:1px solid #1a0e08;border-radius:4px;padding:3px 5px;text-align:center">
            <div style="font-size:9px;color:#8a7a6a">👆 Taps</div>
            <div style="font-size:14px;font-weight:700;color:#70b0d0" id="stat-taps">0</div>
          </div>
        </div>
        <div id="skills-list"></div>
        <div id="milestones-area"></div>
        <div id="skill-upgs-area" class="su"></div>
      </div>
      <div class="tz" id="skills-tap" onclick="G.tapSkills()">
        <div class="tz-icon">⚡</div>
        <div class="tz-hint">Meditate</div>
        <div class="tz-sub">+general XP & gold</div>
      </div>
    </div>
    <div class="pane" id="talents-pane">
      <div class="pane-body">
        <div class="t-scroll">
        <div class="tg" id="talents-grid"></div>
      </div>
      </div>
